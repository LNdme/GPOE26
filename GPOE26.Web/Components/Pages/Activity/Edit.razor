@page "/activities/edit/{Id:guid}"
@rendermode InteractiveServer

<PageTitle>Modifier activité – GPOE26</PageTitle>

<style>
    .text-navy { color: #174ea6 !important; }
    .btn-navy { background-color: #174ea6; color: white; border: none; font-weight: 500; padding: 0.5rem 1.5rem; border-radius: 4px; }
    .btn-navy:hover { background-color: #123d82; color: white; }
    .form-section { max-width: 720px; margin: 0 auto; }
</style>

<div class="container py-5">
    <div class="form-section">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/activities" class="text-navy text-decoration-none">Activités</a></li>
                <li class="breadcrumb-item active">Modifier</li>
            </ol>
        </nav>

        @if (_loading)
        {
            <div class="text-center py-5"><div class="spinner-border text-navy"></div></div>
        }
        else if (_item is null)
        {
            <div class="alert alert-warning">Activité introuvable.</div>
            <a href="/activities" class="btn btn-outline-secondary">Retour</a>
        }
        else
        {
            <h1 class="fw-bold mb-4" style="font-size:1.8rem; color:#202124;">Modifier l'activité</h1>
            @if (!string.IsNullOrEmpty(_error)) { <div class="alert alert-danger">@_error</div> }

            <EditForm Model="_item" OnValidSubmit="Submit" FormName="EditActivityForm">
                <DataAnnotationsValidator />
                <div class="mb-3">
                    <label class="form-label fw-semibold">Nom *</label>
                    <InputText @bind-Value="_item.Name" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description *</label>
                    <InputTextArea @bind-Value="_item.Description" class="form-control" rows="4" />
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Catégorie</label>
                        <InputSelect @bind-Value="_item.Category" class="form-select">
                            <option value="Sport">Sport</option>
                            <option value="Art">Art</option>
                            <option value="Science">Science</option>
                            <option value="Club">Club</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Horaire</label>
                        <InputText @bind-Value="_item.Schedule" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Enseignant responsable</label>
                    <InputText @bind-Value="_item.ResponsibleTeacher" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Image URL</label>
                    <InputText @bind-Value="_item.ImageUrl" class="form-control" />
                </div>
                <div class="form-check mb-4">
                    <InputCheckbox @bind-Value="_item.IsActive" class="form-check-input" id="isActive" />
                    <label class="form-check-label" for="isActive">Active</label>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-navy" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> } Enregistrer
                    </button>
                    <a href="/activities" class="btn btn-outline-secondary">Annuler</a>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    [Parameter] public Guid Id { get; set; }
    private SchoolActivity? _item;
    private bool _loading = true, _saving;
    private string? _error;

    protected override async Task OnInitializedAsync() { _item = await Api.GetActivityByIdAsync(Id); _loading = false; }

    private async Task Submit()
    {
        if (_item is null) return;
        _saving = true; _error = null;
        var ok = await Api.UpdateActivityAsync(Id, _item);
        _saving = false;
        if (ok) Nav.NavigateTo("/activities");
        else _error = "Erreur lors de la mise à jour.";
    }
}
