@page "/hierarchy/edit/{Id:int}"
@rendermode InteractiveServer

<PageTitle>Modifier membre – GPOE26</PageTitle>

<style>
    .text-navy { color: #174ea6 !important; }
    .btn-navy { background-color: #174ea6; color: white; border: none; font-weight: 500; padding: 0.5rem 1.5rem; border-radius: 4px; }
    .btn-navy:hover { background-color: #123d82; color: white; }
    .form-section { max-width: 720px; margin: 0 auto; }
</style>

<div class="container py-5">
    <div class="form-section">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/hierarchy" class="text-navy text-decoration-none">Hiérarchie</a></li>
                <li class="breadcrumb-item active">Modifier</li>
            </ol>
        </nav>

        @if (_loading)
        {
            <div class="text-center py-5"><div class="spinner-border text-navy"></div></div>
        }
        else if (_item is null)
        {
            <div class="alert alert-warning">Membre introuvable.</div>
            <a href="/hierarchy" class="btn btn-outline-secondary">Retour</a>
        }
        else
        {
            <h1 class="fw-bold mb-4" style="font-size:1.8rem; color:#202124;">Modifier le membre</h1>
            @if (!string.IsNullOrEmpty(_error)) { <div class="alert alert-danger">@_error</div> }

            <EditForm Model="_item" OnValidSubmit="Submit" FormName="EditHierarchyForm">
                <DataAnnotationsValidator />
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Nom</label>
                        <InputText @bind-Value="_item.Name" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Prénom</label>
                        <InputText @bind-Value="_item.PreName" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Rôle *</label>
                    <InputSelect @bind-Value="_item.Role" class="form-select">
                        <option value="Administration">Administration</option>
                        <option value="Enseignants">Enseignants</option>
                        <option value="Étudiants">Étudiants</option>
                    </InputSelect>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <InputTextArea @bind-Value="_item.Description" class="form-control" rows="3" />
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Département</label>
                        <InputText @bind-Value="_item.Department" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Spécialisation</label>
                        <InputText @bind-Value="_item.Specialization" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Email</label>
                    <InputText @bind-Value="_item.Email" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Image URL</label>
                    <InputText @bind-Value="_item.ImageUrl" class="form-control" />
                </div>
                <div class="mb-4">
                    <label class="form-label fw-semibold">Citation</label>
                    <InputTextArea @bind-Value="_item.Citation" class="form-control" rows="2" />
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-navy" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> } Enregistrer
                    </button>
                    <a href="/hierarchy" class="btn btn-outline-secondary">Annuler</a>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    private Hierarchy? _item;
    private bool _loading = true, _saving;
    private string? _error;

    protected override async Task OnInitializedAsync() { _item = await Api.GetHierarchyByIdAsync(Id); _loading = false; }

    private async Task Submit()
    {
        if (_item is null) return;
        _saving = true; _error = null;
        var ok = await Api.UpdateHierarchyAsync(Id, _item);
        _saving = false;
        if (ok) Nav.NavigateTo("/hierarchy");
        else _error = "Erreur lors de la mise à jour.";
    }
}
