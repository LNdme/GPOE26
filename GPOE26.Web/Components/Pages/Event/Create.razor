@page "/events/create"
@rendermode InteractiveServer

<PageTitle>Créer un événement – GPOE26</PageTitle>

<style>
    .text-navy { color: #174ea6 !important; }
    .btn-navy { background-color: #174ea6; color: white; border: none; font-weight: 500; padding: 0.5rem 1.5rem; border-radius: 4px; }
    .btn-navy:hover { background-color: #123d82; color: white; }
    .form-section { max-width: 720px; margin: 0 auto; }
</style>

<div class="container py-5">
    <div class="form-section">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/events" class="text-navy text-decoration-none">Événements</a></li>
                <li class="breadcrumb-item active">Nouveau</li>
            </ol>
        </nav>

        <h1 class="fw-bold mb-4" style="font-size:1.8rem; color:#202124;">Créer un événement</h1>

        @if (!string.IsNullOrEmpty(_errorMessage)) { <div class="alert alert-danger">@_errorMessage</div> }

        <EditForm Model="_ev" OnValidSubmit="Submit" FormName="CreateEventForm">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label fw-semibold">Titre *</label>
                <InputText @bind-Value="_ev.Title" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Description *</label>
                <InputTextArea @bind-Value="_ev.Description" class="form-control" rows="4" />
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Date de début *</label>
                    <InputDate @bind-Value="_ev.StartDate" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Date de fin</label>
                    <InputDate @bind-Value="_ev.EndDate" class="form-control" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Lieu</label>
                    <InputText @bind-Value="_ev.Location" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Type</label>
                    <InputSelect @bind-Value="_ev.Type" class="form-select">
                        <option value="Général">Général</option>
                        <option value="JPOE">JPOE</option>
                        <option value="Sportif">Sportif</option>
                        <option value="Culturel">Culturel</option>
                        <option value="Administratif">Administratif</option>
                        <option value="Voyage">Voyage</option>
                    </InputSelect>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Image (URL ou Upload)</label>
                <div class="input-group">
                    <InputText @bind-Value="_ev.ImageUrl" class="form-control" />
                    <InputFile OnChange="HandleImageUpload" class="form-control" accept="image/*" />
                </div>
                @if (_isUploading)
                {
                    <div class="form-text text-info">Téléchargement en cours...</div>
                }
            </div>

            <div class="form-check mb-4">
                <InputCheckbox @bind-Value="_ev.IsPublic" class="form-check-input" id="isPublic" />
                <label class="form-check-label" for="isPublic">Événement public</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-navy" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> } Créer
                </button>
                <a href="/events" class="btn btn-outline-secondary">Annuler</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private SchoolEvent _ev = new() { StartDate = DateTime.Today, EndDate = DateTime.Today };
    private bool _saving;
    private string? _errorMessage;
    private bool _isUploading = false;

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        _isUploading = true;
        try
        {
            var file = e.File;
            if (file.Size > 5 * 1024 * 1024)
            {
                _errorMessage = "Fichier trop volumineux (max 5MB).";
                return;
            }
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            var url = await Api.UploadImageAsync(stream, file.Name);
            if (url != null)
            {
                _ev.ImageUrl = url;
            }
            else _errorMessage = "Erreur upload.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Erreur upload : {ex.Message}";
        }
        finally
        {
            _isUploading = false;
            StateHasChanged();
        }
    }
    private async Task Submit()
    {
        _saving = true; _errorMessage = null;
        var ok = await Api.CreateEventAsync(_ev);
        _saving = false;
        if (ok) Nav.NavigateTo("/events");
        else _errorMessage = "Erreur lors de la création.";
    }
}
