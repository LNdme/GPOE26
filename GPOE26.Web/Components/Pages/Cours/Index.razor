@page "/cours"
@rendermode InteractiveServer

<PageTitle>Mes Cours – GPOE26</PageTitle>



<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="section-title mb-0">Mes Cours</h1>
        <a href="/cours/create" class="btn btn-brand"><i class="bi bi-plus-lg me-1"></i> Nouveau Cours</a>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-brand-dark"></div></div>
    }
    else if (!_courses.Any())
    {
        <div class="text-center py-5 text-muted-chic">
            <p class="fs-5">Vous n'avez pas encore de cours.</p>
            <a href="/cours/create" class="btn btn-brand">Créer mon premier cours</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var c in _courses)
            {
                <div class="col-md-4">
                    <div class="card card-elegant h-100 border-0">
                        <div class="card-body d-flex flex-column p-4">
                            <div class="d-flex gap-2 mb-3">
                                <span class="badge bg-slate-100 text-brand-dark px-2 py-1">@c.Subject</span>
                                <span class="badge @(c.ContentType.ToString() == "Pdf" ? "bg-danger bg-opacity-10 text-danger" : "bg-success bg-opacity-10 text-success") px-2 py-1">
                                    @(c.ContentType.ToString() == "Pdf" ? "📄 PDF" : "📝 Texte")
                                </span>
                            </div>
                            <h5 class="card-title fw-bold" style="color: var(--slate-900);">@c.Title</h5>
                            @if (!string.IsNullOrEmpty(c.Description))
                            {
                                <p class="card-text text-muted-chic small flex-grow-1">@Truncate(c.Description, 100)</p>
                            }
                            <small class="text-muted-chic mb-4">Créé le @c.CreatedAt.ToString("dd MMM yyyy")</small>
                            <div class="d-flex gap-2 mt-auto">
                                <a href="@($"/learning/course/{c.Id}")" class="btn btn-brand btn-sm flex-fill">📖 Étudier</a>
                                <a href="@($"/cours/edit/{c.Id}")" class="btn btn-brand-outline btn-sm">Modifier</a>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => ConfirmDel(c)"><i class="bi bi-trash"></i></button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_toDel is not null)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.4);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header"><h5 class="modal-title">Confirmer la suppression</h5><button type="button" class="btn-close" @onclick="CancelDel"></button></div>
                <div class="modal-body"><p>Supprimer <strong>@_toDel.Title</strong> ?</p></div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDel">Annuler</button>
                    <button class="btn btn-danger" @onclick="Del" disabled="@_deleting">
                        @if (_deleting) { <span class="spinner-border spinner-border-sm me-1"></span> } Supprimer
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true, _deleting;
    private List<CourseSummaryDto> _courses = new();
    private CourseSummaryDto? _toDel;

    protected override async Task OnInitializedAsync() => await Load();
    private async Task Load() { _loading = true; _courses = await Api.GetMyCoursesAsync(); _loading = false; }
    private void ConfirmDel(CourseSummaryDto c) => _toDel = c;
    private void CancelDel() => _toDel = null;
    private async Task Del()
    {
        if (_toDel is null) return;
        _deleting = true;
        await Api.DeleteCourseAsync(_toDel.Id);
        _toDel = null; _deleting = false;
        await Load();
    }
    private static string Truncate(string t, int m) => t.Length <= m ? t : t[..m] + "…";
}
