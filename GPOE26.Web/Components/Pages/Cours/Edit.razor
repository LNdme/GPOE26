@page "/cours/edit/{Id:guid}"
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>Modifier un Cours – GPOE26</PageTitle>

<style>
    .text-navy { color: #174ea6 !important; }
    .btn-navy { background-color: #174ea6; color: white; border: none; font-weight: 500; padding: 0.5rem 1.5rem; border-radius: 4px; }
    .btn-navy:hover { background-color: #123d82; color: white; }
    .form-section { max-width: 1000px; margin: 0 auto; }
    
    .md-editor-container {
        display: flex;
        gap: 1.5rem;
        min-height: 400px;
    }
    .md-editor-pane {
        flex: 1;
        display: flex;
        flex-direction: column;
    }
    .md-textarea {
        flex: 1;
        font-family: 'Fira Code', 'Cascadia Code', Consolas, monospace;
        font-size: 0.9rem;
        resize: vertical;
        border: 1px solid #dadce0;
        border-radius: 8px;
        padding: 1rem;
        min-height: 400px;
    }
    .md-preview-pane {
        flex: 1;
        border: 1px solid #dadce0;
        border-radius: 8px;
        padding: 1.5rem;
        background: #fafafa;
        overflow-y: auto;
        min-height: 400px;
        max-height: 800px;
    }
</style>

<div class="container py-5">
    <div class="form-section">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/cours" class="text-navy text-decoration-none">Mes Cours</a></li>
                <li class="breadcrumb-item active">Modifier</li>
            </ol>
        </nav>

        @if (_loading)
        {
            <div class="text-center py-5"><div class="spinner-border text-navy"></div></div>
        }
        else if (_course is null)
        {
            <div class="alert alert-warning">Cours introuvable.</div>
            <a href="/cours" class="btn btn-outline-secondary">Retour</a>
        }
        else
        {
            <h1 class="fw-bold mb-4" style="font-size:1.8rem; color:#202124;">Modifier le cours</h1>
            @if (!string.IsNullOrEmpty(_error)) { <div class="alert alert-danger">@_error</div> }

            <EditForm Model="_form" OnValidSubmit="Submit" FormName="EditCourseForm">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Titre *</label>
                    <InputText @bind-Value="_form.Title" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Matière *</label>
                    <InputText @bind-Value="_form.Subject" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <InputTextArea @bind-Value="_form.Description" class="form-control" rows="3" />
                </div>

                @if (_course.ContentType == ContentType.Text)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-end mb-2">
                            <div>
                                <label class="form-label fw-semibold mb-0">Contenu du cours (Markdown)</label>
                                <p class="text-muted small mb-0">L'éditeur a été mis à jour pour supporter le Markdown complet !</p>
                            </div>
                            <div class="d-flex gap-2">
                                <label class="btn btn-outline-secondary btn-sm mb-0 position-relative">
                                    📷 Insérer une image
                                    <InputFile OnChange="HandleDirectImageUpload" accept="image/*" class="position-absolute" style="opacity: 0; width: 0; height: 0;" />
                                </label>
                            </div>
                        </div>
                        
                        @if (_isUploadingImage)
                        {
                            <div class="alert alert-info py-2 small">Téléchargement de l'image en cours...</div>
                        }

                        <div class="md-editor-container">
                        <!-- Éditeur Markdown -->
                        <div class="md-editor-pane">
                            <div class="md-toolbar d-flex flex-wrap gap-1 p-2 bg-light border-bottom">
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="@(() => InsertMarkdown("md-editor", "# ", ""))" title="Titre 1">H1</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="@(() => InsertMarkdown("md-editor", "## ", ""))" title="Titre 2">H2</button>
                                <div class="vr mx-1"></div>
                                <button type="button" class="btn btn-sm btn-outline-secondary fw-bold" @onclick="@(() => InsertMarkdown("md-editor", "**", "**"))" title="Gras">B</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary fst-italic" @onclick="@(() => InsertMarkdown("md-editor", "_", "_"))" title="Italique">I</button>
                                <div class="vr mx-1"></div>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="@(() => InsertMarkdown("md-editor", "- ", ""))" title="Liste à puces">• Liste</button>
                                <div class="vr mx-1"></div>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="@(() => InsertMarkdown("md-editor", "```\n", "\n```"))" title="Bloc de code">{'}'} Code</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="@(() => InsertMarkdown("md-editor", "$$ ", " $$"))" title="Formule mathématique">∑ Maths</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="@(() => InsertMarkdown("md-editor", "\n| Titre 1 | Titre 2 |\n|---|---|\n| Ligne 1 | Ligne 1 |\n", ""))" title="Tableau">⊞ Tab</button>
                            </div>
                            <textarea id="md-editor" class="md-textarea" 
                                          placeholder="Éditez votre cours en Markdown ici..."
                                          @bind="_markdownContent" @bind:event="oninput"></textarea>
                            </div>
                            <div class="md-preview-pane">
                                @if (string.IsNullOrWhiteSpace(_markdownContent))
                                {
                                    <div class="text-muted text-center mt-5">Aperçu du rendu Markdown.</div>
                                }
                                else
                                {
                                    <GPOE26.Web.Components.UI.MarkdownViewer Content="@_markdownContent" />
                                }
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-info">
                        Ce cours a été créé à partir d'un PDF. Le contenu textuel est extrait automatiquement.
                    </div>
                }

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-navy" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> } Enregistrer
                    </button>
                    <a href="/cours" class="btn btn-outline-secondary">Annuler</a>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    [Parameter] public Guid Id { get; set; }
    private CourseDto? _course;
    private EditFormModel _form = new();
    private string _markdownContent = "";
    private bool _isUploadingImage = false;
    private bool _loading = true, _saving;
    private string? _error;

    private class EditFormModel
    {
        public string Title { get; set; } = "";
        public string Subject { get; set; } = "";
        public string? Description { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        _course = await Api.GetCourseAsync(Id);
        if (_course is not null)
        {
            _form = new EditFormModel
            {
                Title = _course.Title,
                Subject = _course.Subject,
                Description = _course.Description
            };

            // Charger les sections existantes et les formater en Markdown
            if (_course.Sections is { Count: > 0 })
            {
                if (_course.Sections.Count == 1 && _course.Sections[0].Type == SectionType.Paragraph)
                {
                    _markdownContent = _course.Sections[0].Content;
                }
                else
                {
                    // Migration à la volée des vieilles sections
                    var sb = new System.Text.StringBuilder();
                    foreach (var s in _course.Sections.OrderBy(x => x.Order))
                    {
                        if (s.Type == SectionType.Heading) sb.AppendLine($"{new string('#', s.Level > 0 ? s.Level : 1)} {s.Content}\n");
                        else if (s.Type == SectionType.Paragraph) sb.AppendLine($"{s.Content}\n");
                        else if (s.Type == SectionType.Image) sb.AppendLine($"\n![Image]({s.Content})\n");
                    }
                    _markdownContent = sb.ToString().Trim();
                }
            }
            else if (!string.IsNullOrEmpty(_course.ExtractedText) && _course.ContentType == ContentType.Text)
            {
                _markdownContent = _course.ExtractedText;
            }
        }
        _loading = false;
    }

    private async Task HandleDirectImageUpload(InputFileChangeEventArgs e)
    {
        _isUploadingImage = true;
        _error = null;
        try
        {
            var file = e.File;
            if (file.Size > 5 * 1024 * 1024)
            {
                _error = "L'image est trop volumineuse (max 5MB).";
                return;
            }
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            var url = await Api.UploadImageAsync(stream, file.Name);
            if (url != null) 
            {
                var imageMarkdown = $"\n![{file.Name}]({url})\n";
                _markdownContent += imageMarkdown;
            }
            else 
            {
                _error = "Erreur lors du téléchargement de l'image.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Erreur upload : {ex.Message}";
        }
        finally
        {
            _isUploadingImage = false;
            StateHasChanged();
        }
    }

    private async Task InsertMarkdown(string elementId, string startTag, string endTag)
    {
        var newValue = await JS.InvokeAsync<string>("markdownInterop.insertAtCursor", elementId, startTag, endTag);
        _markdownContent = newValue;
        StateHasChanged();
    }

    private async Task Submit()
    {
        _saving = true; _error = null;

        var sections = _course!.ContentType == ContentType.Text
            ? new List<CreateSectionDto> { new CreateSectionDto(SectionType.Paragraph, _markdownContent, 0, 0) }
            : null;

        var request = new UpdateCourseRequest(_form.Title, _form.Subject, _form.Description, sections);
        var ok = await Api.UpdateCourseAsync(Id, request);
        _saving = false;
        if (ok) Nav.NavigateTo("/cours");
        else _error = "Erreur lors de la mise à jour.";
    }
}
