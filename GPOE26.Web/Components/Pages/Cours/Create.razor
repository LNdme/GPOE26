@page "/cours/create"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Créer un Cours – GPOE26</PageTitle>

<style>
    .text-navy { color: #174ea6 !important; }
    .btn-navy { background-color: #174ea6; color: white; border: none; font-weight: 500; padding: 0.5rem 1.5rem; border-radius: 4px; }
    .btn-navy:hover { background-color: #123d82; color: white; }
    .form-section { max-width: 1000px; margin: 0 auto; }
    .upload-zone { border: 2px dashed #dadce0; border-radius: 8px; padding: 2rem; text-align: center; cursor: pointer; transition: border-color 0.2s; }
    .upload-zone:hover { border-color: #174ea6; }
    
    .md-editor-container {
        display: flex;
        gap: 1.5rem;
        min-height: 400px;
    }
    .md-editor-pane {
        flex: 1;
        display: flex;
        flex-direction: column;
    }
    .md-textarea {
        flex: 1;
        font-family: 'Fira Code', 'Cascadia Code', Consolas, monospace;
        font-size: 0.9rem;
        resize: vertical;
        border: 1px solid #dadce0;
        border-radius: 8px;
        padding: 1rem;
        min-height: 400px;
    }
    .md-preview-pane {
        flex: 1;
        border: 1px solid #dadce0;
        border-radius: 8px;
        padding: 1.5rem;
        background: #fafafa;
        overflow-y: auto;
        min-height: 400px;
        max-height: 800px;
    }
</style>

<div class="container py-5">
    <div class="form-section">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/cours" class="text-navy text-decoration-none">Mes Cours</a></li>
                <li class="breadcrumb-item active">Nouveau</li>
            </ol>
        </nav>

        <h1 class="fw-bold mb-4" style="font-size:1.8rem; color:#202124;">Créer un cours</h1>

        @if (!string.IsNullOrEmpty(_error)) { <div class="alert alert-danger">@_error</div> }

        <EditForm Model="_form" OnValidSubmit="Submit" FormName="CreateCourseForm">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label fw-semibold">Titre *</label>
                <InputText @bind-Value="_form.Title" class="form-control" placeholder="ex: Introduction à l'algorithmique" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Matière *</label>
                <InputText @bind-Value="_form.Subject" class="form-control" placeholder="ex: Informatique, Mathématiques..." />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Description</label>
                <InputTextArea @bind-Value="_form.Description" class="form-control" rows="3" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Type de contenu</label>
                <div class="d-flex gap-3">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="contentType" id="typeText" checked="@(!_isPdf)" @onchange="() => _isPdf = false" />
                        <label class="form-check-label" for="typeText">📝 Saisir du contenu structuré</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="contentType" id="typePdf" checked="@_isPdf" @onchange="() => _isPdf = true" />
                        <label class="form-check-label" for="typePdf">📄 Uploader un PDF</label>
                    </div>
                </div>
            </div>

            @if (!_isPdf)
            {
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-end mb-2">
                        <div>
                            <label class="form-label fw-semibold mb-0">Contenu du cours (Markdown) *</label>
                            <p class="text-muted small mb-0">Utilisez la syntaxe Markdown pour styliser le texte, ajouter des équations ($$) et du code.</p>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-outline-primary btn-sm" @onclick="GenerateWithAI" disabled="@_isGeneratingAI">
                                @if (_isGeneratingAI) { <span class="spinner-border spinner-border-sm"></span> }
                                ✨ Générer le plan (IA)
                            </button>
                            <label class="btn btn-outline-secondary btn-sm mb-0 position-relative">
                                📷 Insérer une image
                                <InputFile OnChange="HandleDirectImageUpload" accept="image/*" class="position-absolute" style="opacity: 0; width: 0; height: 0;" />
                            </label>
                        </div>
                    </div>
                    
                    @if (_isUploadingImage)
                    {
                        <div class="alert alert-info py-2 small">Téléchargement de l'image en cours...</div>
                    }

                    <div class="md-editor-container">
                        <!-- Éditeur Markdown -->
                        <div class="md-editor-pane">
                            <div class="md-toolbar d-flex flex-wrap gap-1 p-2 bg-light border-bottom">
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="@(() => InsertMarkdown("md-editor", "# ", ""))" title="Titre 1">H1</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="@(() => InsertMarkdown("md-editor", "## ", ""))" title="Titre 2">H2</button>
                                <div class="vr mx-1"></div>
                                <button type="button" class="btn btn-sm btn-outline-secondary fw-bold" @onclick="@(() => InsertMarkdown("md-editor", "**", "**"))" title="Gras">B</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary fst-italic" @onclick="@(() => InsertMarkdown("md-editor", "_", "_"))" title="Italique">I</button>
                                <div class="vr mx-1"></div>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="@(() => InsertMarkdown("md-editor", "- ", ""))" title="Liste à puces">• Liste</button>
                                <div class="vr mx-1"></div>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="@(() => InsertMarkdown("md-editor", "```\n", "\n```"))" title="Bloc de code">{'}'} Code</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="@(() => InsertMarkdown("md-editor", "$$ ", " $$"))" title="Formule mathématique">∑ Maths</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="@(() => InsertMarkdown("md-editor", "\n| Titre 1 | Titre 2 |\n|---|---|\n| Ligne 1 | Ligne 1 |\n", ""))" title="Tableau">⊞ Tab</button>
                            </div>
                            <textarea id="md-editor" class="md-textarea" 
                                      placeholder="# Titre du cours&#10;&#10;Commencez à rédiger votre cours ici..."
                                      @bind="_markdownContent" @bind:event="oninput"></textarea>
                        </div>
                        
                        <!-- Prévisualisation en direct -->
                        <div class="md-preview-pane">
                            @if (string.IsNullOrWhiteSpace(_markdownContent))
                            {
                                <div class="text-muted text-center mt-5">Aperçu du rendu Markdown s'affichera ici.</div>
                            }
                            else
                            {
                                <GPOE26.Web.Components.UI.MarkdownViewer Content="@_markdownContent" />
                            }
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="mb-3">
                    <label class="form-label fw-semibold">Fichier PDF</label>
                    <div class="upload-zone">
                        <InputFile OnChange="HandleFileSelected" accept=".pdf" />
                        @if (_selectedFile is not null)
                        {
                            <p class="mt-2 mb-0 text-success">📄 @_selectedFile.Name (@FormatSize(_selectedFile.Size))</p>
                        }
                        else
                        {
                            <p class="text-muted mb-0">Cliquez ou glissez un fichier PDF ici</p>
                        }
                    </div>
                </div>
            }

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-navy" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> } Créer le cours
                </button>
                <a href="/cours" class="btn btn-outline-secondary">Annuler</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private CourseFormModel _form = new();
    private bool _isPdf = false;
    private bool _saving;
    private string? _error;
    private IBrowserFile? _selectedFile;
    private string _markdownContent = "";
    private bool _isUploadingImage = false;
    private bool _isGeneratingAI = false;

    private class CourseFormModel
    {
        public string Title { get; set; } = "";
        public string Subject { get; set; } = "";
        public string? Description { get; set; }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e) => _selectedFile = e.File;

    private async Task HandleDirectImageUpload(InputFileChangeEventArgs e)
    {
        _isUploadingImage = true;
        _error = null;
        try
        {
            var file = e.File;
            if (file.Size > 5 * 1024 * 1024)
            {
                _error = "L'image est trop volumineuse (max 5MB).";
                return;
            }
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            var url = await Api.UploadImageAsync(stream, file.Name);
            if (url != null) 
            {
                var imageMarkdown = $"\n![{file.Name}]({url})\n";
                _markdownContent += imageMarkdown;
            }
            else 
            {
                _error = "Erreur lors du téléchargement de l'image.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Erreur upload : {ex.Message}";
        }
        finally
        {
            _isUploadingImage = false;
            StateHasChanged();
        }
    }
    
    private async Task InsertMarkdown(string elementId, string startTag, string endTag)
    {
        var newValue = await JS.InvokeAsync<string>("markdownInterop.insertAtCursor", elementId, startTag, endTag);
        _markdownContent = newValue;
        StateHasChanged();
    }

    private async Task GenerateWithAI()
    {
        if (string.IsNullOrWhiteSpace(_form.Subject) || string.IsNullOrWhiteSpace(_form.Title))
        {
            await JS.InvokeVoidAsync("alert", "Veuillez préciser le titre du cours et le domaine d'enseignement matière avant de générer.");
            return;
        }

        _isGeneratingAI = true;
        StateHasChanged();

        try
        {
            var draft = await Api.GenerateCourseDraftAsync(_form.Subject, $"Le nom du cours est précisement : {_form.Title}");

            if (!string.IsNullOrWhiteSpace(draft))
            {
                if (string.IsNullOrWhiteSpace(_markdownContent))
                    _markdownContent = draft;
                else
                    _markdownContent += $"\n\n---\n\n{draft}";
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "La génération du cours a échoué. Veuillez réessayer.");
            }
        }
        catch (Exception)
        {
            await JS.InvokeVoidAsync("alert", "Erreur réseau lors de la communication avec l'assistant virtuel.");
        }
        finally
        {
            _isGeneratingAI = false;
        }
    }

    private async Task Submit()
    {
        _saving = true; _error = null;

        if (string.IsNullOrWhiteSpace(_form.Title) || string.IsNullOrWhiteSpace(_form.Subject))
        {
            _error = "Le titre et la matière sont obligatoires.";
            _saving = false;
            return;
        }

        if (!_isPdf && string.IsNullOrWhiteSpace(_markdownContent))
        {
            _error = "Le contenu du cours est vide.";
            _saving = false;
            return;
        }

        var sections = _isPdf ? null : new List<CreateSectionDto>
        {
            new CreateSectionDto(SectionType.Paragraph, _markdownContent, 0, 0)
        };

        var request = new CreateCourseRequest(
            _form.Title,
            _form.Subject,
            _form.Description,
            sections
        );

        var created = await Api.CreateCourseAsync(request);
        if (created is null)
        {
            _error = "Erreur lors de la création du cours.";
            _saving = false;
            return;
        }

        if (_isPdf && _selectedFile is not null)
        {
            using var stream = _selectedFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            var ok = await Api.UploadCoursePdfAsync(created.Id, stream, _selectedFile.Name);
            if (!ok)
            {
                _error = "Le cours a été créé mais l'upload du PDF a échoué.";
                _saving = false;
                return;
            }
        }

        _saving = false;
        Nav.NavigateTo("/cours");
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
    };
}
