@page "/cours/create"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Créer un Cours – GPOE26</PageTitle>

<style>
    .text-navy { color: #174ea6 !important; }
    .btn-navy { background-color: #174ea6; color: white; border: none; font-weight: 500; padding: 0.5rem 1.5rem; border-radius: 4px; }
    .btn-navy:hover { background-color: #123d82; color: white; }
    .form-section { max-width: 800px; margin: 0 auto; }
    .upload-zone { border: 2px dashed #dadce0; border-radius: 8px; padding: 2rem; text-align: center; cursor: pointer; transition: border-color 0.2s; }
    .upload-zone:hover { border-color: #174ea6; }
    .section-block { border: 1px solid #dadce0; border-radius: 8px; padding: 1rem; margin-bottom: 0.75rem; background: #fafafa; position: relative; }
    .section-block:hover { border-color: #174ea6; }
    .section-type-badge { font-size: 0.75rem; font-weight: 600; padding: 0.2rem 0.5rem; border-radius: 4px; }
    .badge-heading { background: #e8f0fe; color: #174ea6; }
    .badge-paragraph { background: #e6f4ea; color: #137333; }
    .badge-image { background: #fef7e0; color: #e37400; }
    .add-section-bar { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; }
</style>

<div class="container py-5">
    <div class="form-section">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/cours" class="text-navy text-decoration-none">Mes Cours</a></li>
                <li class="breadcrumb-item active">Nouveau</li>
            </ol>
        </nav>

        <h1 class="fw-bold mb-4" style="font-size:1.8rem; color:#202124;">Créer un cours</h1>

        @if (!string.IsNullOrEmpty(_error)) { <div class="alert alert-danger">@_error</div> }

        <EditForm Model="_form" OnValidSubmit="Submit" FormName="CreateCourseForm">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label fw-semibold">Titre *</label>
                <InputText @bind-Value="_form.Title" class="form-control" placeholder="ex: Introduction à l'algorithmique" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Matière *</label>
                <InputText @bind-Value="_form.Subject" class="form-control" placeholder="ex: Informatique, Mathématiques..." />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Description</label>
                <InputTextArea @bind-Value="_form.Description" class="form-control" rows="3" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Type de contenu</label>
                <div class="d-flex gap-3">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="contentType" id="typeText" checked="@(!_isPdf)" @onchange="() => _isPdf = false" />
                        <label class="form-check-label" for="typeText">📝 Saisir du contenu structuré</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="contentType" id="typePdf" checked="@_isPdf" @onchange="() => _isPdf = true" />
                        <label class="form-check-label" for="typePdf">📄 Uploader un PDF</label>
                    </div>
                </div>
            </div>

            @if (!_isPdf)
            {
                <div class="mb-3">
                    <label class="form-label fw-semibold">Contenu du cours *</label>
                    <p class="text-muted small mb-2">Ajoutez des titres, paragraphes et images pour structurer votre cours.</p>

                    <div class="add-section-bar">
                        <button type="button" class="btn btn-outline-primary btn-sm" @onclick='() => AddSection(SectionType.Heading, 1)'>+ Titre H1</button>
                        <button type="button" class="btn btn-outline-primary btn-sm" @onclick='() => AddSection(SectionType.Heading, 2)'>+ Titre H2</button>
                        <button type="button" class="btn btn-outline-primary btn-sm" @onclick='() => AddSection(SectionType.Heading, 3)'>+ Titre H3</button>
                        <button type="button" class="btn btn-outline-success btn-sm" @onclick='() => AddSection(SectionType.Paragraph, 0)'>+ Paragraphe</button>
                        <button type="button" class="btn btn-outline-warning btn-sm" @onclick='() => AddSection(SectionType.Image, 0)'>+ Image (URL)</button>
                    </div>

                    @if (!_sections.Any())
                    {
                        <div class="text-center py-4 text-muted" style="border: 2px dashed #dadce0; border-radius: 8px;">
                            <p class="mb-0">Aucune section ajoutée. Cliquez sur les boutons ci-dessus pour structurer votre cours.</p>
                        </div>
                    }

                    @for (int i = 0; i < _sections.Count; i++)
                    {
                        var idx = i;
                        var s = _sections[idx];
                        <div class="section-block">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="section-type-badge @GetBadgeClass(s.Type)">
                                        @GetTypeLabel(s.Type, s.Level)
                                    </span>
                                    <span class="text-muted small">#@(idx + 1)</span>
                                </div>
                                <div class="d-flex gap-1">
                                    @if (idx > 0)
                                    {
                                        <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1" @onclick="() => MoveUp(idx)">↑</button>
                                    }
                                    @if (idx < _sections.Count - 1)
                                    {
                                        <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1" @onclick="() => MoveDown(idx)">↓</button>
                                    }
                                    <button type="button" class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => RemoveSection(idx)">✕</button>
                                </div>
                            </div>

                            @if (s.Type == SectionType.Heading)
                            {
                                <input type="text" class="form-control" placeholder="Titre..."
                                       value="@s.Content" @onchange="(e) => s.Content = e.Value?.ToString() ?? string.Empty" />
                            }
                            else if (s.Type == SectionType.Paragraph)
                            {
                                <textarea class="form-control" rows="4" placeholder="Écrivez votre paragraphe ici..."
                                          @onchange="(e) => s.Content = e.Value?.ToString() ?? string.Empty">@s.Content</textarea>
                            }
                            else
                            {
                                <input type="url" class="form-control" placeholder="https://exemple.com/image.jpg"
                                       value="@s.Content" @onchange="(e) => s.Content = e.Value?.ToString() ?? string.Empty" />
                                @if (!string.IsNullOrEmpty(s.Content))
                                {
                                    <img src="@s.Content" alt="Aperçu" class="mt-2 rounded" style="max-width: 100%; max-height: 200px;" />
                                }
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="mb-3">
                    <label class="form-label fw-semibold">Fichier PDF</label>
                    <div class="upload-zone">
                        <InputFile OnChange="HandleFileSelected" accept=".pdf" />
                        @if (_selectedFile is not null)
                        {
                            <p class="mt-2 mb-0 text-success">📄 @_selectedFile.Name (@FormatSize(_selectedFile.Size))</p>
                        }
                        else
                        {
                            <p class="text-muted mb-0">Cliquez ou glissez un fichier PDF ici</p>
                        }
                    </div>
                </div>
            }

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-navy" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> } Créer le cours
                </button>
                <a href="/cours" class="btn btn-outline-secondary">Annuler</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private CourseFormModel _form = new();
    private bool _isPdf = false;
    private bool _saving;
    private string? _error;
    private IBrowserFile? _selectedFile;
    private List<SectionModel> _sections = new();

    private class CourseFormModel
    {
        public string Title { get; set; } = "";
        public string Subject { get; set; } = "";
        public string? Description { get; set; }
    }

    private class SectionModel
    {
        public SectionType Type { get; set; }
        public string Content { get; set; } = "";
        public int Level { get; set; }
    }

    private void AddSection(SectionType type, int level)
    {
        _sections.Add(new SectionModel { Type = type, Level = level });
    }

    private void RemoveSection(int index) => _sections.RemoveAt(index);

    private void MoveUp(int index)
    {
        if (index <= 0) return;
        (_sections[index], _sections[index - 1]) = (_sections[index - 1], _sections[index]);
    }

    private void MoveDown(int index)
    {
        if (index >= _sections.Count - 1) return;
        (_sections[index], _sections[index + 1]) = (_sections[index + 1], _sections[index]);
    }

    private void HandleFileSelected(InputFileChangeEventArgs e) => _selectedFile = e.File;

    private async Task Submit()
    {
        _saving = true; _error = null;

        if (string.IsNullOrWhiteSpace(_form.Title) || string.IsNullOrWhiteSpace(_form.Subject))
        {
            _error = "Le titre et la matière sont obligatoires.";
            _saving = false;
            return;
        }

        if (!_isPdf && !_sections.Any())
        {
            _error = "Ajoutez au moins une section au cours.";
            _saving = false;
            return;
        }

        var sections = _isPdf ? null : _sections.Select((s, i) => new CreateSectionDto(
            s.Type, s.Content, i, s.Level
        )).ToList();

        var request = new CreateCourseRequest(
            _form.Title,
            _form.Subject,
            _form.Description,
            sections
        );

        var created = await Api.CreateCourseAsync(request);
        if (created is null)
        {
            _error = "Erreur lors de la création du cours.";
            _saving = false;
            return;
        }

        if (_isPdf && _selectedFile is not null)
        {
            using var stream = _selectedFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            var ok = await Api.UploadCoursePdfAsync(created.Id, stream, _selectedFile.Name);
            if (!ok)
            {
                _error = "Le cours a été créé mais l'upload du PDF a échoué.";
                _saving = false;
                return;
            }
        }

        _saving = false;
        Nav.NavigateTo("/cours");
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
    };

    private static string GetBadgeClass(SectionType type) => type switch
    {
        SectionType.Heading => "badge-heading",
        SectionType.Paragraph => "badge-paragraph",
        SectionType.Image => "badge-image",
        _ => ""
    };

    private static string GetTypeLabel(SectionType type, int level) => type switch
    {
        SectionType.Heading => $"Titre H{level}",
        SectionType.Paragraph => "Paragraphe",
        SectionType.Image => "Image",
        _ => ""
    };
}
