@page "/learning"
@rendermode InteractiveServer

<PageTitle>Apprentissage – GPOE26</PageTitle>



<div class="container py-5">
    <div class="hero-learning text-white p-5 rounded-4 mb-4 shadow-sm" style="background: linear-gradient(135deg, var(--slate-800) 0%, var(--slate-900) 100%);">
        <h1 class="fw-bold mb-3" style="letter-spacing: -0.5px;">🎓 Espace d'Apprentissage</h1>
        <p class="mb-0 opacity-75 fs-5">Étudiez vos cours, posez des questions à l'assistant IA et testez vos connaissances avec des quiz interactifs.</p>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-brand-dark"></div><p class="text-muted-chic mt-2">Chargement de vos cours...</p></div>
    }
    else if (!_courses.Any())
    {
        <div class="text-center py-5">
            <div class="display-1 mb-3">📚</div>
            <h4 class="text-muted-chic mb-3">Vous n'avez aucun cours pour le moment</h4>
            <p class="text-muted-chic mb-4">Créez ou uploadez un cours pour commencer à apprendre avec l'IA.</p>
            <a href="/cours/create" class="btn btn-brand btn-lg shadow-sm">Créer un cours</a>
        </div>
    }
    else
    {
        <h2 class="section-title">Mes Cours</h2>
        <div class="row g-4">
            @foreach (var c in _courses)
            {
                <div class="col-md-4">
                    <div class="card card-elegant h-100 border-0">
                        <div class="card-body d-flex flex-column p-4">
                            <span class="badge bg-slate-100 text-brand-dark mb-3 align-self-start px-2 py-1">@c.Subject</span>
                            <h5 class="card-title fw-bold mb-3" style="color: var(--slate-900);">@c.Title</h5>
                            @if (!string.IsNullOrEmpty(c.Description))
                            {
                                <p class="card-text text-muted-chic small flex-grow-1">@Truncate(c.Description, 120)</p>
                            }
                            <small class="text-muted-chic mb-4">@c.CreatedAt.ToString("dd MMM yyyy")</small>
                            <a href="@($"/learning/course/{c.Id}")" class="btn btn-brand w-100 mt-auto">
                                📖 Commencer l'étude
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private List<CourseSummaryDto> _courses = new();

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _courses = await Api.GetMyCoursesAsync();
        _loading = false;
    }

    private static string Truncate(string t, int m) => t.Length <= m ? t : t[..m] + "…";
}
