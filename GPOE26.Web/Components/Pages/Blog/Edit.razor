@page "/blog/edit/{Id:guid}"
@rendermode InteractiveServer

<PageTitle>Modifier l'article – GPOE26</PageTitle>

<style>
    .text-navy { color: #174ea6 !important; }
    .btn-navy { background-color: #174ea6; color: white; border: none; font-weight: 500; padding: 0.5rem 1.5rem; border-radius: 4px; }
    .btn-navy:hover { background-color: #123d82; color: white; }
    .form-section { max-width: 720px; margin: 0 auto; }
</style>

<div class="container py-5">
    <div class="form-section">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/blog" class="text-navy text-decoration-none">Actualités</a></li>
                <li class="breadcrumb-item active">Modifier</li>
            </ol>
        </nav>

        @if (_loading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-navy"></div>
                <p class="text-muted mt-2">Chargement...</p>
            </div>
        }
        else if (_article is null)
        {
            <div class="alert alert-warning">Article introuvable.</div>
            <a href="/blog" class="btn btn-outline-secondary">Retour</a>
        }
        else
        {
            <h1 class="fw-bold mb-4" style="font-size:1.8rem; color:#202124;">Modifier l'article</h1>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger">@_errorMessage</div>
            }

            <EditForm Model="_article" OnValidSubmit="HandleSubmit" FormName="EditArticleForm">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Titre *</label>
                    <InputText @bind-Value="_article.Title" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Slug</label>
                    <InputText @bind-Value="_article.Slug" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Catégorie</label>
                    <InputSelect @bind-Value="_article.Category" class="form-select">
                        <option value="Général">Général</option>
                        <option value="Sport">Sport</option>
                        <option value="Culturel">Culturel</option>
                        <option value="Administratif">Administratif</option>
                    </InputSelect>
                </div>

                <div class="mb-3">
                <label class="form-label fw-semibold">Image (URL ou Upload)</label>
                <div class="input-group">
                    <InputText @bind-Value="_article.ImageUrl" class="form-control" />
                    <InputFile OnChange="HandleImageUpload" class="form-control" accept="image/*" />
                </div>
                @if (_isUploading)
                {
                    <div class="form-text text-info">Téléchargement en cours...</div>
                }
            </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Extrait</label>
                    <InputTextArea @bind-Value="_article.Excerpt" class="form-control" rows="2" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Contenu *</label>
                    <InputTextArea @bind-Value="_article.Content" class="form-control" rows="10" />
                </div>

                <div class="form-check mb-4">
                    <InputCheckbox @bind-Value="_article.IsPublished" class="form-check-input" id="isPublished" />
                    <label class="form-check-label" for="isPublished">Publié</label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-navy" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Enregistrer
                    </button>
                    <a href="/blog" class="btn btn-outline-secondary">Annuler</a>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private NewArticle? _article;
    private bool _loading = true;
    private bool _saving = false;
    private string? _errorMessage;
    private bool _isUploading = false;

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        _isUploading = true;
        try
        {
            var file = e.File;
            if (file.Size > 5 * 1024 * 1024)
            {
                _errorMessage = "Fichier trop volumineux (max 5MB).";
                return;
            }
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            var url = await Api.UploadImageAsync(stream, file.Name);
            if (url != null && _article != null)
            {
                _article.ImageUrl = url;
            }
            else _errorMessage = "Erreur upload.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Erreur upload : {ex.Message}";
        }
        finally
        {
            _isUploading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _article = await Api.GetNewsByIdAsync(Id);
        _loading = false;
    }

    private async Task HandleSubmit()
    {
        if (_article is null) return;
        _saving = true;
        _errorMessage = null;

        _article.UpdatedAt = DateTime.UtcNow;
        var ok = await Api.UpdateNewsAsync(Id, _article);
        _saving = false;

        if (ok)
        {
            Nav.NavigateTo("/blog");
        }
        else
        {
            _errorMessage = "Erreur lors de la mise à jour. Veuillez réessayer.";
        }
    }
}
