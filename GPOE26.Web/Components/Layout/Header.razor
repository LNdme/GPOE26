@inject GPOE26.Web.Services.ApiClient Api
@inject NavigationManager Nav
@inject AuthService Auth
@rendermode InteractiveServer

<header class="lt-header sticky-top shadow-sm">
    <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #174ea6;">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2 m-0" href="/">
                <div class="lt-logo-circle">LT</div>
                <div class="d-flex flex-column lh-1">
                    <span class="fw-bold fs-5 text-white">LT Nanga-Eboko</span>
                    <span class="text-white-50" style="font-size: 0.75rem;">Excellence & Innovation</span>
                </div>
            </a>

            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#ltNavbar" aria-controls="ltNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="ltNavbar">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-lg-3 fw-medium">
                    <li class="nav-item"><NavLink class="nav-link px-2" href="/" Match="NavLinkMatch.All">Accueil</NavLink></li>
                    <li class="nav-item"><NavLink class="nav-link px-2" href="/cours">Cours</NavLink></li>
                    <li class="nav-item"><NavLink class="nav-link px-2" href="/blog">Actualités</NavLink></li>
                    <li class="nav-item"><NavLink class="nav-link px-2" href="/activities">Activités</NavLink></li>
                    <li class="nav-item"><NavLink class="nav-link px-2" href="/evenements">Événements</NavLink></li>
                </ul>

                <div class="d-flex align-items-center gap-3">
                    <form class="position-relative d-none d-xl-block" role="search">
                        <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-white-50"></i>
                        <input type="search" class="form-control form-control-sm rounded-pill ps-5 bg-white bg-opacity-10 border-0 text-white placeholder-white" placeholder="Rechercher..." aria-label="Search" style="width: 200px;" />
                    </form>

                    <div class="dropdown">
                        @if (Auth.IsAuthenticated)
                        {
                            <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                                <div class="user-avatar bg-white text-navy fw-bold rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2">
                                <li><a class="dropdown-item py-2" href="/cours"><i class="bi bi-book me-2 text-navy"></i> Mes cours</a></li>
                                <li><a class="dropdown-item py-2" href="/profil"><i class="bi bi-person me-2 text-navy"></i> Profil</a></li>
                                <li><hr class="dropdown-divider my-1" /></li>
                                <li><button class="dropdown-item py-2 text-danger" @onclick="DoLogout"><i class="bi bi-box-arrow-right me-2"></i> Se déconnecter</button></li>
                            </ul>
                        }
                        else
                        {
                            <div class="d-flex gap-2">
                                <a href="/login" class="btn btn-outline-light btn-sm rounded-pill px-3 fw-medium">Connexion</a>
                                <a href="/register" class="btn btn-light text-navy btn-sm rounded-pill px-3 fw-bold">S'inscrire</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </nav>
</header>

<style>
    .lt-header .navbar-nav .nav-link { color: rgba(255, 255, 255, 0.85); transition: color 0.2s ease; border-bottom: 2px solid transparent; padding-bottom: 2px; }
    .lt-header .navbar-nav .nav-link:hover, .lt-header .navbar-nav .nav-link.active { color: white; border-bottom-color: white; }
    .lt-logo-circle { width: 42px; height: 42px; border-radius: 50%; background-color: white; color: #174ea6; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.1rem; letter-spacing: -0.5px; }
    .placeholder-white::placeholder { color: rgba(255, 255, 255, 0.6) !important; }
    .text-navy { color: #174ea6 !important; }
</style>

@code {
    private Contact? contact;

    protected override async Task OnInitializedAsync()
    {
        try { contact = await Api.GetPrimaryContactAsync(); }
        catch { }
    }

    private void DoLogout()
    {
        Auth.Logout();
        Nav.NavigateTo("/");
    }
}
