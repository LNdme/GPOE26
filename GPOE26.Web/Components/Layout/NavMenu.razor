@inject GPOE26.Web.Services.AuthService Auth
@inject NavigationManager Nav
@implements IDisposable
@rendermode InteractiveServer

<style>
    .lt-header { background-color: #174ea6; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .lt-header .navbar-nav .nav-link { color: rgba(255, 255, 255, 0.85); transition: color 0.2s ease; border-bottom: 2px solid transparent; padding-bottom: 2px; font-weight: 500; }
    .lt-header .navbar-nav .nav-link:hover, .lt-header .navbar-nav .nav-link.active { color: white; border-bottom-color: white; }
    .lt-logo-circle { width: 42px; height: 42px; border-radius: 50%; background-color: white; color: #174ea6; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.1rem; letter-spacing: -0.5px; }
    .text-navy { color: #174ea6 !important; }
    .placeholder-white::placeholder { color: rgba(255, 255, 255, 0.6) !important; }
</style>

<nav class="navbar navbar-expand-lg navbar-dark lt-header sticky-top py-2 shadow-sm">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center gap-2 m-0 pe-4" href="/">
            <div class="lt-logo-circle shadow-sm">LT</div>
            <div class="d-flex flex-column lh-1">
                <span class="fw-bold fs-5 text-white">LT Nanga-Eboko</span>
                <span class="text-white-50" style="font-size: 0.75rem;">Excellence & Innovation</span>
            </div>
        </a>

        <button class="navbar-toggler border-0 shadow-none" type="button" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse @(collapseNavMenu ? "" : "show")">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-lg-2">
                <li class="nav-item">
                    <NavLink class="nav-link px-3" href="/" Match="NavLinkMatch.All">Accueil</NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link px-3" href="/blog">Actualités</NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link px-3" href="/events">Événements</NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link px-3" href="/activities">Activités</NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link px-3" href="/hierarchy">L'Établissement</NavLink>
                </li>

                @if (Auth.IsAuthenticated)
                {
                    <li class="nav-item">
                        <NavLink class="nav-link px-3" href="/cours">Mes Cours</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link px-3" href="/learning">Apprentissage</NavLink>
                    </li>
                }
            </ul>

            <ul class="navbar-nav ms-auto align-items-center">
                @if (Auth.IsAuthenticated)
                {
                    <li class="nav-item dropdown dropdown-menu-end">
                        <a href="#" class="nav-link d-flex align-items-center gap-2" id="userMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="bg-white text-navy fw-bold rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 0.85rem;">
                                @(Auth.Profile?.Username?.Substring(0, 1).ToUpper() ?? "U")
                            </div>
                            <span class="d-none d-lg-block text-white">@Auth.Profile?.Username</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="userMenu">
                            <li><a class="dropdown-item py-2" href="/cours"><i class="bi bi-book me-2 text-navy"></i> Mes cours</a></li>
                            <li><a class="dropdown-item py-2" href="/profil"><i class="bi bi-person me-2 text-navy"></i> Profil</a></li>
                            <li><hr class="dropdown-divider my-1" /></li>
                            <li><button class="dropdown-item py-2 text-danger" @onclick="Logout"><i class="bi bi-box-arrow-right me-2"></i> Se déconnecter</button></li>
                        </ul>
                    </li>
                    <li class="nav-item d-lg-none mt-2">
                        <button class="btn btn-outline-light btn-sm w-100" @onclick="Logout">Déconnexion</button>
                    </li>
                }
                else
                {
                    <li class="nav-item me-2 mb-2 mb-lg-0 w-100 text-center">
                        <a class="btn btn-outline-light btn-sm rounded-pill px-4 fw-medium w-100" href="/login">Connexion</a>
                    </li>
                    <li class="nav-item w-100 text-center">
                        <a class="btn btn-light text-navy btn-sm rounded-pill px-4 fw-bold w-100 shadow-sm" href="/register">S'inscrire</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

@code {
    private bool collapseNavMenu = true;

    protected override void OnInitialized()
    {
        // On s'abonne à l'événement pour rafraîchir l'UI lors de la connexion/déconnexion
        Auth.OnAuthChanged += StateHasChanged;
    }

    public void Dispose()
    {
        // On se désabonne proprement pour éviter les fuites de mémoire
        Auth.OnAuthChanged -= StateHasChanged;
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void Logout()
    {
        Auth.Logout();
        // Redirection vers l'accueil public avec un rechargement forcé pour nettoyer l'état de la page
        Nav.NavigateTo("/", forceLoad: true); 
    }
}