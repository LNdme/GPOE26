@inject GPOE26.Web.Services.ApiClient Api
@using GPOE26.Web.Services
@inject NavigationManager Nav
@rendermode InteractiveServer

<footer class="lt-footer text-white" style="background-color: #0b2b5e; padding-top: 60px; padding-bottom: 20px;">
    <div class="container">
        <div class="row gy-4 mb-5">
            <div class="col-12 col-lg-4 pe-lg-5">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="lt-logo-square">LT</div>
                    <div class="fw-bold fs-5">LT Nanga-Eboko</div>
                </div>
                <p class="text-white-50" style="line-height: 1.6;">
                    La plateforme d'apprentissage d'excellence du Lycée Technique de Nanga-Eboko. <br />
                    Apprendre, Construire, Réussir.
                </p>
                @if (contact != null && !string.IsNullOrEmpty(contact.Email))
                {
                    <div class="d-flex align-items-center gap-2 mt-3 text-white-50">
                        <i class="bi bi-envelope"></i>
                        <a href="mailto:@contact.Email" class="text-white-50 text-decoration-none hover-white">@contact.Email</a>
                    </div>
                }
            </div>

            <div class="col-6 col-md-4 col-lg-2 offset-lg-1">
                <h6 class="fw-bold text-uppercase mb-3" style="color: #6ea8ff; letter-spacing: 0.5px; font-size: 0.85rem;">Pédagogie</h6>
                <ul class="list-unstyled d-flex flex-column gap-2 mb-0">
                    <li><a href="/cours" class="footer-link">Cours en ligne</a></li>
                    <li><a href="/projets" class="footer-link">Projets</a></li>
                    <li><a href="/quiz" class="footer-link">Évaluations</a></li>
                    <li><a href="/bibliotheque" class="footer-link">Ressources</a></li>
                </ul>
            </div>

            <div class="col-6 col-md-4 col-lg-2">
                <h6 class="fw-bold text-uppercase mb-3" style="color: #6ea8ff; letter-spacing: 0.5px; font-size: 0.85rem;">Vie Scolaire</h6>
                <ul class="list-unstyled d-flex flex-column gap-2 mb-0">
                    <li><a href="/evenements" class="footer-link">Événements</a></li>
                    <li><a href="/activities" class="footer-link">Activités</a></li>
                    <li><a href="/blog" class="footer-link">Actualités</a></li>
                    <li><a href="/reglement" class="footer-link">Règlement</a></li>
                </ul>
            </div>

            <div class="col-12 col-md-4 col-lg-3">
                <h6 class="fw-bold text-uppercase mb-3" style="color: #6ea8ff; letter-spacing: 0.5px; font-size: 0.85rem;">L'Établissement</h6>
                <ul class="list-unstyled d-flex flex-column gap-2 mb-0">
                    <li><a href="/a-propos" class="footer-link">À propos de nous</a></li>
                    <li><a href="/contact" class="footer-link">Contact</a></li>
                    <li><a href="/administration" class="footer-link">Administration</a></li>
                </ul>
            </div>
        </div>

        <hr style="border-color: rgba(255, 255, 255, 0.15);" class="mb-4" />

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <div class="text-white-50 small">
                © @DateTime.UtcNow.Year Lycée Technique de Nanga-Eboko. Tous droits réservés.
            </div>
            <div class="d-flex gap-3 social-links">
                <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                <a href="#" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                <a href="#" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
            </div>
        </div>
    </div>
</footer>

<style>
    .lt-logo-square { width: 48px; height: 48px; border-radius: 8px; background-color: #174ea6; color: white; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.25rem; letter-spacing: -0.5px; border: 2px solid rgba(255,255,255,0.2); }
    .footer-link { color: rgba(255, 255, 255, 0.7); text-decoration: none; transition: color 0.2s ease, transform 0.2s ease; display: inline-block; }
    .footer-link:hover { color: white; transform: translateX(2px); }
    .hover-white:hover { color: white !important; }
    .social-links a { color: rgba(255, 255, 255, 0.7); font-size: 1.25rem; transition: color 0.2s ease, transform 0.2s ease; display: inline-block; }
    .social-links a:hover { color: white; transform: translateY(-2px); }
</style>

@code {
    private Contact? contact;

    protected override async Task OnInitializedAsync()
    {
        try { contact = await Api.GetPrimaryContactAsync(); }
        catch { }
    }
}